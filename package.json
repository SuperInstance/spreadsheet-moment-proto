{
  "name": "polln",
  "version": "0.1.0",
  "description": "Pattern-Organized Large Language Network - A distributed intelligence system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "polln": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest src/core/__tests__/integration.test.ts",
    "test:api": "jest src/api/__tests__/server.test.ts",
    "test:cli": "jest src/cli/__tests__",
    "test:llm": "jest src/core/__tests__/integration/llm --testTimeout=120000",
    "test:kv": "jest src/core/__tests__/kv*.test.ts",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli/index.js",
    "bench:kv": "npx tsx src/core/__tests__/kvbenchmarks.ts",
    "bench:ann": "npx tsx src/core/__tests__/ann-index.test.ts",
    "bench:lmcache": "npx tsx src/core/__tests__/lmcache-adapter.test.ts",
    "bench:all": "npm run test && npm run bench:kv"
  },
  "keywords": [
    "distributed-intelligence",
    "agent-system",
    "swarm-intelligence",
    "machine-learning",
    "pattern-organization",
    "cli",
    "colony-management",
    "federated-learning"
  ],
  "author": "POLLN Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/polln"
  },
  "dependencies": {
    "@types/inquirer": "^9.0.9",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "table": "^6.9.0",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
