{
  "name": "polln",
  "version": "0.1.0",
  "description": "Pattern-Organized Large Language Network - A distributed intelligence system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest src/core/__tests__/integration.test.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "distributed-intelligence",
    "agent-system",
    "swarm-intelligence",
    "machine-learning",
    "pattern-organization"
  ],
  "author": "POLLN Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/polln"
  },
  "dependencies": {
    "tslib": "^2.8.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
