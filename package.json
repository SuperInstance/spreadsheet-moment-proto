{
  "name": "polln",
  "version": "0.1.0",
  "description": "Pattern-Organized Large Language Network - A distributed intelligence system",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "polln": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./core": {
      "import": "./dist/core/index.js",
      "types": "./dist/core/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    },
    "./api/client": {
      "import": "./dist/api/client/index.js",
      "types": "./dist/api/client/index.d.ts"
    },
    "./monitoring": {
      "import": "./dist/monitoring/index.js",
      "types": "./dist/monitoring/index.d.ts"
    },
    "./scaling": {
      "import": "./dist/scaling/index.js",
      "types": "./dist/scaling/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest src/core/__tests__/integration.test.ts",
    "test:api": "jest src/api/__tests__/server.test.ts",
    "test:cli": "jest src/cli/__tests__",
    "test:scaling": "jest src/scaling/__tests__",
    "test:llm": "jest src/core/__tests__/integration/llm --testTimeout=120000",
    "test:kv": "jest src/core/__tests__/kv*.test.ts",
    "test:lora": "jest src/core/lora/__tests__",
    "test:multi-colony": "jest src/core/colony-manager/__tests__ src/core/inter-colony/__tests__ src/core/colony-lifecycle/__tests__",
    "prepublishOnly": "npm run build",
    "cli": "node dist/cli/index.js",
    "lora:list": "node dist/cli/index.js lora list",
    "lora:train": "node dist/cli/index.js lora train",
    "lora:benchmark": "node dist/cli/index.js lora benchmark",
    "lora:distill": "node dist/cli/index.js lora distill",
    "colony:list": "node dist/cli/index.js colonies list",
    "colony:create": "node dist/cli/index.js colonies create",
    "colony:status": "node dist/cli/index.js colonies status",
    "colony:scale": "node dist/cli/index.js colonies scale",
    "colony:migrate": "node dist/cli/index.js colonies migrate",
    "scale:status": "node dist/cli/index.js scale status",
    "scale:policy": "node dist/cli/index.js scale policy",
    "scale:manual": "node dist/cli/index.js scale manual",
    "scale:predict": "node dist/cli/index.js scale predict",
    "scale:history": "node dist/cli/index.js scale history",
    "bench": "npx tsx src/benchmarks/cli.ts",
    "bench:run": "npx tsx src/benchmarks/cli.ts run",
    "bench:list": "npx tsx src/benchmarks/cli.ts list",
    "bench:compare": "npx tsx src/benchmarks/cli.ts compare",
    "bench:agent": "npx tsx src/benchmarks/cli.ts run -s agent",
    "bench:comm": "npx tsx src/benchmarks/cli.ts run -s communication",
    "bench:decision": "npx tsx src/benchmarks/cli.ts run -s decision",
    "bench:learning": "npx tsx src/benchmarks/cli.ts run -s learning",
    "bench:kv": "npx tsx src/benchmarks/cli.ts run -s kv-cache",
    "bench:worldmodel": "npx tsx src/benchmarks/cli.ts run -s worldmodel",
    "bench:integration": "npx tsx src/benchmarks/cli.ts run -s integration",
    "bench:all": "npx tsx src/benchmarks/cli.ts run",
    "bench:report": "npx tsx src/benchmarks/cli.ts run --format html --output benchmarks/report.html",
    "bench:baseline": "npx tsx src/benchmarks/cli.ts run --save-baseline benchmarks/baseline.json",
    "bench:ci": "npx tsx src/benchmarks/cli.ts run --format json --output benchmarks/results.json --baseline benchmarks/baseline.json",
    "docs:api": "npx tsx scripts/generate-api-docs.ts",
    "docs:api:serve": "npx http-server docs/api -p 8080 -o",
    "docs:api:watch": "npx nodemon --watch src/api --exec 'npm run docs:api'",
    "demo:multi-colony": "node examples/multi-colony-demo/demo.js",
    "monitor:metrics": "node dist/cli/index.js monitor metrics",
    "monitor:traces": "node dist/cli/index.js monitor traces",
    "monitor:logs": "node dist/cli/index.js monitor logs",
    "monitor:health": "node dist/cli/index.js monitor health",
    "monitor:alerts": "node dist/cli/index.js monitor alerts",
    "monitor:dashboard": "node dist/cli/index.js monitor dashboard"
  },
  "keywords": [
    "distributed-intelligence",
    "agent-system",
    "swarm-intelligence",
    "machine-learning",
    "pattern-organization",
    "cli",
    "colony-management",
    "federated-learning",
    "lora",
    "llm-adapters",
    "expert-systems",
    "model-distillation",
    "monitoring",
    "observability",
    "metrics",
    "tracing",
    "opentelemetry"
  ],
  "author": "POLLN Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/polln"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-metrics-stdout": "^0.53.0",
    "@opentelemetry/exporter-prometheus": "^0.53.0",
    "@opentelemetry/exporter-trace-jaeger": "^1.28.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.53.0",
    "@opentelemetry/exporter-trace-zipkin": "^1.28.0",
    "@opentelemetry/exporter-trace-stdout": "^0.53.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/sdk-metrics": "^1.28.0",
    "@opentelemetry/sdk-trace-base": "^1.28.0",
    "@opentelemetry/sdk-trace-node": "^1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@types/inquirer": "^9.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.3.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "table": "^6.9.0",
    "tslib": "^2.8.1",
    "uuid": "^11.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.13",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
