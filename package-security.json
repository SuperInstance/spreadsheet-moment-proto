{
  "name": "@spreadsheet-moment/security",
  "version": "1.1.0",
  "description": "Security utilities with Ed25519, JWT, Argon2id, CORS, CSRF, and rate limiting",
  "main": "./dist/core/security/index.js",
  "types": "./dist/core/security/index.d.ts",
  "scripts": {
    "build:security": "tsc --project tsconfig.json",
    "test:security": "jest --testPathPattern=security",
    "test:security:watch": "jest --testPathPattern=security --watch",
    "test:security:coverage": "jest --testPathPattern=security --coverage",
    "audit:security": "npm audit && npm audit --production",
    "lint:security": "eslint src/core/security --ext .ts",
    "migrate:security": "node scripts/migrate-passwords.js"
  },
  "keywords": [
    "security",
    "authentication",
    "cryptography",
    "ed25519",
    "jwt",
    "argon2",
    "cors",
    "csrf",
    "rate-limiting"
  ],
  "author": "Spreadsheet Moment Security Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/spreadsheet-moment/polln"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "argon2": "^0.40.1",
    "jsonwebtoken": "^9.0.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "express-rate-limit": "^7.1.5",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/cors": "^2.8.17",
    "@types/csurf": "^1.11.5",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.6",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5"
  },
  "peerDependencies": {
    "express": "^4.18.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "security": {
    "jwt": {
      "algorithm": "RS256",
      "expiresIn": "1h",
      "refreshExpiresIn": "24h"
    },
    "password": {
      "algorithm": "argon2id",
      "memoryCost": 65536,
      "timeCost": 3,
      "parallelism": 4
    },
    "cors": {
      "enabled": true,
      "strict": true
    },
    "csrf": {
      "enabled": true,
      "tokenLength": 32,
      "tokenExpiry": 3600000
    },
    "rateLimit": {
      "enabled": true,
      "windowMs": 60000,
      "maxRequests": 100
    }
  }
}
