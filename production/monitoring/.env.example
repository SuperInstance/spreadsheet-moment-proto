# =============================================================================
# SuperInstance Monitoring Stack - Environment Configuration
# =============================================================================
# Copy this file to .env and configure with your settings
# =============================================================================

# -----------------------------------------------------------------------------
# Monitoring Configuration
# -----------------------------------------------------------------------------

# Prometheus metrics server port
PROMETHEUS_PORT=9090

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# Jaeger Distributed Tracing
# -----------------------------------------------------------------------------

# Jaeger agent host
JAEGER_HOST=jaeger

# Jaeger agent port
JAEGER_PORT=6831

# Enable/disable tracing (true/false)
ENABLE_TRACING=true

# -----------------------------------------------------------------------------
# Alerting
# -----------------------------------------------------------------------------

# Slack webhook URL for alerts
# Get from: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Alertmanager configuration
ALERTMANAGER_INTERVAL=30s
ALERTMANAGER_TIMEOUT=10s

# -----------------------------------------------------------------------------
# Grafana Configuration
# -----------------------------------------------------------------------------

# Grafana admin credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# Grafana anonymous access (true/false)
GRAFANA_ANONYMOUS_ENABLED=false

# -----------------------------------------------------------------------------
# SuperInstance Configuration
# -----------------------------------------------------------------------------

# Replica URLs for health checks
# Comma-separated list of replica endpoints
REPLICA_URLS=http://node-1:8000,http://node-2:8000,http://node-3:8000

# Consensus service URL
CONSENSUS_URL=http://consensus:8001

# Node ID for this instance
NODE_ID=node-1

# Cluster name
CLUSTER_NAME=superinstance-prod

# Environment name (dev, staging, prod)
ENVIRONMENT=production

# -----------------------------------------------------------------------------
# GPU Monitoring Configuration
# -----------------------------------------------------------------------------

# Enable GPU monitoring (true/false)
ENABLE_GPU_MONITORING=true

# GPU temperature alert threshold (Celsius)
GPU_TEMP_ALERT_THRESHOLD=85

# GPU memory alert threshold (percentage)
GPU_MEMORY_ALERT_THRESHOLD=90

# -----------------------------------------------------------------------------
# Alert Thresholds
# -----------------------------------------------------------------------------

# Latency thresholds (milliseconds)
LATENCY_WARNING_THRESHOLD=50
LATENCY_CRITICAL_THRESHOLD=100

# Fast path ratio threshold (percentage)
FAST_PATH_RATIO_THRESHOLD=90

# Error rate thresholds (percentage)
ERROR_RATE_WARNING_THRESHOLD=1
ERROR_RATE_CRITICAL_THRESHOLD=5

# Memory usage threshold (percentage)
MEMORY_USAGE_THRESHOLD=90

# CPU usage threshold (percentage)
CPU_USAGE_THRESHOLD=80

# Disk usage threshold (percentage)
DISK_USAGE_THRESHOLD=90

# Consensus failure rate threshold (percentage)
CONSENSUS_FAILURE_RATE_THRESHOLD=5

# CRDT merge duration threshold (seconds)
CRDT_MERGE_DURATION_THRESHOLD=1.0

# -----------------------------------------------------------------------------
# Data Retention
# -----------------------------------------------------------------------------

# Prometheus data retention
PROMETHEUS_RETENTION_TIME=15d

# Grafana session timeout
GRAFANA_SESSION_TIMEOUT=86400

# -----------------------------------------------------------------------------
# Backup Configuration
# -----------------------------------------------------------------------------

# Backup directory
BACKUP_DIR=/backup/monitoring

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# Enable automatic backups (true/false)
ENABLE_AUTO_BACKUP=true

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# -----------------------------------------------------------------------------
# Notification Settings
# -----------------------------------------------------------------------------

# Alert severity levels to notify (warning, critical)
NOTIFY_SEVERITIES=warning,critical

# Alert cooldown period (seconds)
ALERT_COOLDOWN=300

# -----------------------------------------------------------------------------
# Advanced Configuration
# -----------------------------------------------------------------------------

# Prometheus scrape interval
SCRAPE_INTERVAL=15s

# Prometheus evaluation interval
EVALUATION_INTERVAL=15s

# Enable TLS/SSL (true/false)
ENABLE_TLS=false

# TLS certificate path
TLS_CERT_PATH=/etc/ssl/certs/monitoring.crt

# TLS key path
TLS_KEY_PATH=/etc/ssl/private/monitoring.key

# -----------------------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------------------

# Enable debug mode (true/false)
DEBUG=false

# Enable profiling (true/false)
ENABLE_PROFILING=false

# Profiling port
PROFILING_PORT=6060

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable experimental features
ENABLE_EXPERIMENTAL_FEATURES=false

# Enable beta features
ENABLE_BETA_FEATURES=false

# -----------------------------------------------------------------------------
# Third-Party Integrations
# -----------------------------------------------------------------------------

# PagerDuty integration key (optional)
PAGERDUTY_INTEGRATION_KEY=

# Datadog API key (optional)
DATADOG_API_KEY=

# DataDog site
DATADOG_SITE=datadoghq.com

# -----------------------------------------------------------------------------
# Performance Tuning
# -----------------------------------------------------------------------------

# Max concurrent health checks
MAX_CONCURRENT_HEALTH_CHECKS=10

# Health check timeout (seconds)
HEALTH_CHECK_TIMEOUT=5

# Metrics collection interval (seconds)
METRICS_COLLECTION_INTERVAL=10

# Alert evaluation interval (seconds)
ALERT_EVALUATION_INTERVAL=30

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------

# Enable authentication (true/false)
ENABLE_AUTH=true

# Authentication provider (basic, oauth, ldap)
AUTH_PROVIDER=basic

# Enable RBAC (true/false)
ENABLE_RBAC=true

# Session secret (generate with: openssl rand -hex 32)
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Docker Configuration
# -----------------------------------------------------------------------------

# Docker network
DOCKER_NETWORK=monitoring

# Docker registry
DOCKER_REGISTRY=docker.io

# Image tag
IMAGE_TAG=latest

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------

# Log format (json, text)
LOG_FORMAT=json

# Log output (stdout, file, both)
LOG_OUTPUT=stdout

# Log file path (if LOG_OUTPUT=file or both)
LOG_FILE_PATH=/var/log/superinstance/monitoring.log

# Log rotation (true/false)
ENABLE_LOG_ROTATION=true

# Max log size (MB)
MAX_LOG_SIZE=100

# Max log files
MAX_LOG_FILES=10

# -----------------------------------------------------------------------------
# Metrics Export Configuration
# -----------------------------------------------------------------------------

# Enable metrics export (true/false)
ENABLE_METRICS_EXPORT=true

# Metrics export format (prometheus, json)
METRICS_EXPORT_FORMAT=prometheus

# Metrics export endpoint
METRICS_EXPORT_ENDPOINT=/metrics

# -----------------------------------------------------------------------------
# Custom Configuration
# -----------------------------------------------------------------------------

# Custom labels for Prometheus (comma-separated key=value pairs)
CUSTOM_LABELS=team=platform,owner=superinstance

# Custom environment variables (comma-separated key=value pairs)
CUSTOM_ENV_VARS=

# -----------------------------------------------------------------------------
# Notes
# -----------------------------------------------------------------------------
#
# 1. After copying this file to .env, update the values with your actual configuration
# 2. Never commit .env to version control (it's already in .gitignore)
# 3. Use strong passwords and secrets in production
# 4. Keep webhook URLs and API keys secure
# 5. Test configuration changes in development first
# 6. Document any custom configuration for your team
# 7. Rotate secrets periodically
# 8. Use different values for dev/staging/production environments
#
# -----------------------------------------------------------------------------
