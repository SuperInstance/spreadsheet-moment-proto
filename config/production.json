{
  "api": {
    "port": 3000,
    "host": "0.0.0.0",
    "cors": {
      "origin": ["https://polln.example.com"],
      "credentials": true
    },
    "rateLimit": {
      "requestsPerMinute": 1000,
      "burstLimit": 100
    },
    "auth": {
      "enableAuth": true,
      "tokenExpiresIn": 86400
    }
  },
  "redis": {
    "url": "redis://polln-redis:6379",
    "password": "",
    "maxRetriesPerRequest": 3,
    "retryStrategy": {
      "maxRetriesPerRequest": 3
    }
  },
  "database": {
    "host": "polln-postgres",
    "port": 5432,
    "database": "polln",
    "ssl": true,
    "pool": {
      "min": 2,
      "max": 20
    }
  },
  "kvCache": {
    "enabled": true,
    "maxSize": 1000000,
    "ttl": 3600,
    "compression": true
  },
  "dreaming": {
    "enabled": true,
    "episodeCount": 100,
    "interval": 86400,
    "worldModelPath": "/app/.polln/worldmodel"
  },
  "federation": {
    "enabled": true,
    "syncInterval": 3600,
    "endpoints": []
  },
  "meadow": {
    "enabled": true,
    "endpoint": "https://meadow.polln.example.com"
  },
  "logging": {
    "level": "info",
    "format": "json"
  },
  "metrics": {
    "enabled": true,
    "port": 9090
  },
  "tracing": {
    "enabled": true,
    "endpoint": "http://jaeger:14268/api/traces",
    "sampleRate": 0.1
  },
  "features": {
    "multiColony": true,
    "loraTraining": true,
    "bytecodeExecution": true,
    "graphEvolution": true
  }
}
