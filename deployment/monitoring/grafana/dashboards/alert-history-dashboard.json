{
  "dashboard": {
    "id": null,
    "title": "Spreadsheet Moment - Alert History",
    "tags": ["alerts", "spreadsheet-moment"],
    "timezone": "browser",
    "schemaVersion": 16,
    "version": 0,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Active Alerts by Severity",
        "type": "stat",
        "targets": [
          {
            "expr": "count(ALERTS{alertstate=\"firing\"}) by (severity)",
            "legendFormat": "{{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short",
            "thresholds": {
              "mode": "series",
              "steps": [
                { "value": 0, "color": "green" },
                { "value": 1, "color": "yellow" },
                { "value": 5, "color": "red" }
              ]
            }
          }
        },
        "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 }
      },
      {
        "id": 2,
        "title": "Total Alerts Fired (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(ALERTS{alertstate=\"firing\"}[24h]))",
            "legendFormat": "Total"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 }
      },
      {
        "id": 3,
        "title": "Alerts Resolved (24h)",
        "type": "stat",
        "targets": [
          {
            "expr": "sum(increase(ALERTS{alertstate=\"inactive\"}[24h]))",
            "legendFormat": "Resolved"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "short"
          }
        },
        "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 }
      },
      {
        "id": 4,
        "title": "Alert Frequency Over Time",
        "type": "graph",
        "targets": [
          {
            "expr": "sum(rate(ALERTS{alertstate=\"firing\"}[5m])) by (severity)",
            "legendFormat": "{{severity}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "aps"
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 }
      },
      {
        "id": 5,
        "title": "Alert Resolution Time",
        "type": "graph",
        "targets": [
          {
            "expr": "avg(ALERTS{alertstate=\"inactive\"} - ALERTS{alertstate=\"firing\"}) by (alertname)",
            "legendFormat": "{{alertname}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          }
        },
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 }
      },
      {
        "id": 6,
        "title": "Active Alerts Table",
        "type": "table",
        "targets": [
          {
            "expr": "ALERTS{alertstate=\"firing\"}",
            "legendFormat": "{{alertname}}"
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true
              },
              "indexByName": {
                "Time": 0,
                "__name__": 1,
                "alertname": 2,
                "alertstate": 3,
                "severity": 4,
                "instance": 5,
                "job": 6
              },
              "renameByName": {}
            }
          }
        ],
        "gridPos": { "h": 16, "w": 24, "x": 0, "y": 16 }
      }
    ]
  }
}
