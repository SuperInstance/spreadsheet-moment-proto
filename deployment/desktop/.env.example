# Spreadsheet Moment Desktop - Environment Variables

# Tauri Configuration
TAURI_PLATFORM=windows
TAURI_DEBUG=true

# Update Server
VITE_UPDATE_SERVER=https://updates.superinstance.ai/spreadsheet-moment
VITE_APP_NAME=Spreadsheet Moment

# API Configuration
VITE_API_URL=https://api.superinstance.ai
VITE_WS_URL=wss://api.superinstance.ai

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_TELEMETRY=false
VITE_ENABLE_UPDATES=true

# Development
VITE_DEV_MODE=true
VITE_LOG_LEVEL=debug

# Build Configuration
VITE_APP_VERSION=1.0.0
VITE_BUILD_DATE=2024-03-14

# Code Signing (Windows)
SPREADSHEET_MOMENT_CERT_THUMBPRINT=

# Code Signing (macOS)
SPREADSHEET_MOMENT_SIGNING_IDENTITY=

# Apple Notarization
APPLE_ID=
APPLE_APP_SPECIFIC_PASSWORD=
APPLE_TEAM_ID=
APPLE_CERTIFICATES_P12=
APPLE_CERTIFICATES_PASSWORD=

# Analytics (Optional)
VITE_GA_ID=
VITE_SENTRY_DSN=
