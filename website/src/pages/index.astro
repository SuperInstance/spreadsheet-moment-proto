---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Button } from '../components/ui/Button';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '../components/ui/Card';
import LearningPathway from '../components/educational/LearningPathway.astro';
import TutorialCard from '../components/educational/TutorialCard.astro';
import AgeBasedInterface from '../components/educational/AgeBasedInterface.astro';
import SuperInstanceTutorial from '../components/educational/SuperInstanceTutorial';
---

<BaseLayout title="SuperInstance.AI - Learn Advanced AI & Mathematics">
  <!-- Hero Section -->
  <section class="section bg-gradient-to-b from-white to-gray-50">
    <div class="container-narrow text-center">
      <div class="animate-fade-in">
        <h1 class="heading-1 mb-6">
          Learn SuperInstance
          <span class="block text-primary-600">AI & Mathematics</span>
        </h1>

        <p class="text-body max-w-2xl mx-auto mb-10">
          Master advanced AI concepts, geometric tensor mathematics, and intelligent systems.
          Designed for students of all ages—from K-12 to university researchers.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
          <Button variant="primary" size="lg" className="sm:w-auto">
            Start Learning Free
          </Button>
          <Button variant="outline" size="lg" className="sm:w-auto">
            Explore Tutorials
          </Button>
          <Button variant="accent" size="lg" className="sm:w-auto">
            Read White Papers
          </Button>
        </div>
      </div>

      {/* Hero Visual - Age-Based Learning */}
      <div class="relative max-w-5xl mx-auto">
        <div class="bg-gradient-to-r from-primary-500/10 to-accent-500/10 rounded-2xl p-8 border border-gray-200">
          <h2 class="heading-2 mb-8 text-center">Choose Your Learning Path</h2>
          <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
            <Card hover padding="md" class="text-center cursor-pointer hover:scale-105 transition-transform">
              <CardHeader>
                <div class="w-16 h-16 rounded-full bg-blue-100 flex items-center justify-center mx-auto mb-4">
                  <span class="text-2xl">👶</span>
                </div>
                <CardTitle class="text-lg">K-5</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm text-gray-600">Basic concepts through games</p>
              </CardContent>
            </Card>

            <Card hover padding="md" class="text-center cursor-pointer hover:scale-105 transition-transform">
              <CardHeader>
                <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center mx-auto mb-4">
                  <span class="text-2xl">🧒</span>
                </div>
                <CardTitle class="text-lg">6-8</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm text-gray-600">Interactive learning</p>
              </CardContent>
            </Card>

            <Card hover padding="md" class="text-center cursor-pointer hover:scale-105 transition-transform">
              <CardHeader>
                <div class="w-16 h-16 rounded-full bg-purple-100 flex items-center justify-center mx-auto mb-4">
                  <span class="text-2xl">👦</span>
                </div>
                <CardTitle class="text-lg">9-12</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm text-gray-600">Advanced concepts</p>
              </CardContent>
            </Card>

            <Card hover padding="md" class="text-center cursor-pointer hover:scale-105 transition-transform">
              <CardHeader>
                <div class="w-16 h-16 rounded-full bg-orange-100 flex items-center justify-center mx-auto mb-4">
                  <span class="text-2xl">🎓</span>
                </div>
                <CardTitle class="text-lg">University</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm text-gray-600">Theoretical foundations</p>
              </CardContent>
            </Card>

            <Card hover padding="md" class="text-center cursor-pointer hover:scale-105 transition-transform">
              <CardHeader>
                <div class="w-16 h-16 rounded-full bg-indigo-100 flex items-center justify-center mx-auto mb-4">
                  <span class="text-2xl">💼</span>
                </div>
                <CardTitle class="text-lg">Professional</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm text-gray-600">Practical applications</p>
              </CardContent>
            </Card>

            <Card hover padding="md" class="text-center cursor-pointer hover:scale-105 transition-transform">
              <CardHeader>
                <div class="w-16 h-16 rounded-full bg-red-100 flex items-center justify-center mx-auto mb-4">
                  <span class="text-2xl">🔬</span>
                </div>
                <CardTitle class="text-lg">Researcher</CardTitle>
              </CardHeader>
              <CardContent>
                <p class="text-sm text-gray-600">Cutting-edge research</p>
              </CardContent>
            </Card>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Learning Features Section -->
  <section class="section">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="heading-2 mb-4">Why Learn With Us?</h2>
        <p class="text-body max-w-3xl mx-auto">
          Master cutting-edge AI and mathematics through interactive, age-appropriate learning experiences.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <Card hover padding="lg">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center mb-4">
              <span class="text-primary-600 font-bold">🎓</span>
            </div>
            <CardTitle>Age-Appropriate Learning</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">
              Content tailored for different age groups—from K-12 games to university-level theoretical foundations.
            </p>
          </CardContent>
        </Card>

        <Card hover padding="lg">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-accent-100 flex items-center justify-center mb-4">
              <span class="text-accent-600 font-bold">🖱️</span>
            </div>
            <CardTitle>Interactive Demos</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">
              Hands-on learning with interactive demonstrations that let you experiment with concepts in real-time.
            </p>
          </CardContent>
        </Card>

        <Card hover padding="lg">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-secondary-100 flex items-center justify-center mb-4">
              <span class="text-secondary-600 font-bold">📚</span>
            </div>
            <CardTitle>Three-Tier White Papers</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">
              Read research at your level: short summaries, full papers, or annotated versions with expert commentary.
            </p>
          </CardContent>
        </Card>

        <Card hover padding="lg">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-primary-100 flex items-center justify-center mb-4">
              <span class="text-primary-600 font-bold">🧩</span>
            </div>
            <CardTitle>Structured Learning Paths</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">
              Follow curated learning pathways that build knowledge progressively from basics to advanced topics.
            </p>
          </CardContent>
        </Card>

        <Card hover padding="lg">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-accent-100 flex items-center justify-center mb-4">
              <span class="text-accent-600 font-bold">🔬</span>
            </div>
            <CardTitle>Cutting-Edge Research</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">
              Learn directly from research papers on geometric tensors, confidence cascades, and AI systems.
            </p>
          </CardContent>
        </Card>

        <Card hover padding="lg">
          <CardHeader>
            <div class="w-12 h-12 rounded-lg bg-secondary-100 flex items-center justify-center mb-4">
              <span class="text-secondary-600 font-bold">👥</span>
            </div>
            <CardTitle>Community Learning</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600">
              Join a community of learners, ask questions, share insights, and collaborate on projects.
            </p>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>

  <!-- Learning Topics Section -->
  <section class="section bg-gray-50">
    <div class="container-wide">
      <div class="text-center mb-12">
        <h2 class="heading-2 mb-4">Explore Learning Topics</h2>
        <p class="text-body max-w-3xl mx-auto">
          Dive into advanced AI and mathematics concepts through structured learning materials.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        <Card hover padding="lg">
          <CardHeader>
            <CardTitle>Geometric Tensor Mathematics</CardTitle>
            <CardDescription>Master compass and straightedge construction mathematics</CardDescription>
          </CardHeader>
          <CardContent>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-center">
                <span class="w-2 h-2 bg-primary-500 rounded-full mr-3"></span>
                Pythagorean prime number systems
              </li>
              <li class="flex items-center">
                <span class="w-2 h-2 bg-primary-500 rounded-full mr-3"></span>
                Permutations, folds, and spin operations
              </li>
              <li class="flex items-center">
                <span class="w-2 h-2 bg-primary-500 rounded-full mr-3"></span>
                Reality-bending SuperInstance concepts
              </li>
              <li class="flex items-center">
                <span class="w-2 h-2 bg-primary-500 rounded-full mr-3"></span>
                Little-data vs big-data paradigms
              </li>
            </ul>
          </CardContent>
        </Card>

        <Card hover padding="lg">
          <CardHeader>
            <CardTitle>AI Systems Architecture</CardTitle>
            <CardDescription>Learn intelligent system design and implementation</CardDescription>
          </CardHeader>
          <CardContent>
            <ul class="space-y-2 text-gray-600">
              <li class="flex items-center">
                <span class="w-2 h-2 bg-accent-500 rounded-full mr-3"></span>
                Confidence cascade deadband triggers
              </li>
              <li class="flex items-center">
                <span class="w-2 h-2 bg-accent-500 rounded-full mr-3"></span>
                Rate-based change mechanics
              </li>
              <li class="flex items-center">
                <span class="w-2 h-2 bg-accent-500 rounded-full mr-3"></span>
                Universal cell architecture
              </li>
              <li class="flex items-center">
                <span class="w-2 h-2 bg-accent-500 rounded-full mr-3"></span>
                SMPbot seed-model-prompt systems
              </li>
            </ul>
          </CardContent>
        </Card>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-8">
        <Card hover padding="md">
          <CardHeader>
            <CardTitle>White Papers</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600 mb-4">
              Read research papers at three levels: short summaries, full papers, and annotated versions.
            </p>
            <Button variant="outline" className="w-full">Browse White Papers</Button>
          </CardContent>
        </Card>

        <Card hover padding="md">
          <CardHeader>
            <CardTitle>Interactive Tutorials</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600 mb-4">
              Hands-on learning with code examples, exercises, and interactive demonstrations.
            </p>
            <Button variant="outline" className="w-full">Start Tutorials</Button>
          </CardContent>
        </Card>

        <Card hover padding="md">
          <CardHeader>
            <CardTitle>Learning Pathways</CardTitle>
          </CardHeader>
          <CardContent>
            <p class="text-gray-600 mb-4">
              Follow structured learning paths from beginner to advanced levels.
            </p>
            <Button variant="outline" className="w-full">Explore Pathways</Button>
          </CardContent>
        </Card>
      </div>
    </div>
  </section>

  <!-- Demo Section -->
  <section class="section bg-gray-900 text-white">
    <div class="container">
      <div class="max-w-4xl mx-auto text-center mb-12">
        <h2 class="heading-2 mb-4">Try SuperInstance Now</h2>
        <p class="text-xl opacity-90">
          Experience AI-powered spreadsheet technology with our interactive demos
        </p>
      </div>

      <SuperInstanceTutorial />

      <div class="text-center mt-8 space-y-4">
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button variant="secondary" href="/demos/spreadsheet" size="lg" className="bg-white text-gray-900">
            Spreadsheet Demo
          </Button>
          <Button variant="secondary" href="/demos/interactive" size="lg" className="bg-white text-gray-900">
            Interactive Visualizations
          </Button>
        </div>
        <p class="text-sm opacity-75">
          Or explore our advanced demos: Confidence Cascades · Pythagorean Calculator · Rate-Based Change
        </p>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section">
    <div class="container-narrow text-center">
      <div class="bg-gradient-to-r from-primary-500 to-accent-500 rounded-2xl p-12 text-white">
        <h2 class="heading-2 mb-6">Ready to Start Learning?</h2>
        <p class="text-xl mb-8 opacity-90">
          Join thousands of students learning advanced AI and mathematics. Free for all learners.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <Button variant="secondary" href="/demos/spreadsheet" size="lg" className="bg-white text-gray-900 hover:bg-gray-100">
            Try Interactive Demo
          </Button>
          <Button variant="outline" href="/tutorials" size="lg" className="border-white text-white hover:bg-white/10">
            Explore Tutorials
          </Button>
          <Button variant="outline" href="/white-papers" size="lg" className="border-white text-white hover:bg-white/10">
            Read White Papers
          </Button>
        </div>
        <p class="text-sm opacity-75 mt-6">
          Completely free educational platform • No registration required • Open to all ages
        </p>
      </div>
    </div>
  </section>
</BaseLayout>