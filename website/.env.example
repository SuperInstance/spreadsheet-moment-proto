# Environment Variables for SuperInstance Website
# Copy this file to .env.local for local development
# For production, set these as environment variables in Cloudflare Pages dashboard

# Site Configuration
SITE_URL=https://superinstance.ai
API_BASE_URL=https://api.superinstance.ai
NODE_ENV=development

# Analytics
ANALYTICS_ID=your-analytics-id-here
GOOGLE_ANALYTICS_ID=UA-XXXXX-Y  # Optional: Google Analytics
PLAUSIBLE_DOMAIN=superinstance.ai  # Optional: Plausible Analytics

# Feature Flags
ENABLE_DEMOS=true
ENABLE_BLOG=true
ENABLE_COMMUNITY=false

# External Services (if needed)
SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Cloudflare (for local development with Wrangler)
CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_ZONE_ID=your-zone-id
CLOUDFLARE_API_TOKEN=your-api-token

# Note: Never commit actual secrets to version control
# These should be set in GitHub Secrets for CI/CD and Cloudflare dashboard for production