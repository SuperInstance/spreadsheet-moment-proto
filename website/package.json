{
  "name": "superinstance-website",
  "version": "0.1.0",
  "description": "SuperInstance.AI marketing website and documentation portal",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.astro",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "deploy:staging": "wrangler pages deploy dist --project-name=superinstance-website --env=staging",
    "deploy:production": "wrangler pages deploy dist --project-name=superinstance-website --env=production",
    "deploy:preview": "wrangler pages deploy dist --project-name=superinstance-website --env=preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:performance": "node performance/run-performance-tests.js",
    "test:security": "node security/run-security-tests.js",
    "test:security:scan": "zap-baseline-crawl.py -t https://localhost:4321",
    "test:security:audit": "npm audit --audit-level=high",
    "test:accessibility": "pa11y-ci --sitemap http://localhost:4321/sitemap.xml",
    "test:all": "npm run test && npm run test:e2e && npm run test:performance && npm run test:security && npm run test:accessibility",
    "qa:bug-report": "node qa/bug-tracking-workflow.js create-bug",
    "qa:list-bugs": "node qa/bug-tracking-workflow.js list-bugs",
    "qa:run-regression": "node qa/bug-tracking-workflow.js run-regression",
    "qa:metrics": "node qa/bug-tracking-workflow.js metrics",
    "qa:help": "node qa/bug-tracking-workflow.js help"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^10.2.0",
    "@astrojs/react": "^4.2.0",
    "@astrojs/sitemap": "^3.2.0",
    "@astrojs/tailwind": "^5.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "astro": "^4.10.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "@playwright/test": "^1.40.0",
    "axe-core": "^4.8.3",
    "eslint": "^8.57.0",
    "eslint-plugin-astro": "^1.2.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-vitest": "^0.3.0",
    "jsdom": "^24.0.0",
    "lighthouse-ci": "^1.0.0",
    "pa11y-ci": "^3.0.0",
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.13.0",
    "typescript": "^5.0.0",
    "vitest": "^1.6.0",
    "wrangler": "^3.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}