{
  "dashboard": {
    "title": "POLLN Colony Operations",
    "description": "Complete operational view of POLLN colony health, performance, and metrics",
    "tags": ["polln", "colony", "production"],
    "timezone": "UTC",
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Colony Health Overview",
        "type": "stat",
        "gridPos": {"x": 0, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "up{job=\"polln-colony\"}",
            "legendFormat": "Colony Up"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "reduceOptions": {
            "calcs": ["lastNotNull"],
            "fields": "",
            "values": false
          }
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Active Agents",
        "type": "stat",
        "gridPos": {"x": 4, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "polln_agents_total",
            "legendFormat": "Agents"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 100},
                {"color": "green", "value": 500}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Decision Latency (P99)",
        "type": "gauge",
        "gridPos": {"x": 8, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(polln_decision_duration_seconds_bucket[5m]))",
            "legendFormat": "P99 Latency"
          }
        ],
        "options": {
          "min": 0,
          "max": 1,
          "thresholds": [
            {"value": 0, "color": "green"},
            {"value": 0.1, "color": "yellow"},
            {"value": 0.5, "color": "red"}
          ]
        }
      },
      {
        "id": 4,
        "title": "Memory Usage",
        "type": "gauge",
        "gridPos": {"x": 12, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "process_resident_memory_bytes{job=\"polln-colony\"} / 1024 / 1024 / 1024",
            "legendFormat": "GB"
          }
        ],
        "options": {
          "min": 0,
          "max": 16,
          "thresholds": [
            {"value": 0, "color": "green"},
            {"value": 8, "color": "yellow"},
            {"value": 14, "color": "red"}
          ]
        }
      },
      {
        "id": 5,
        "title": "CPU Usage",
        "type": "gauge",
        "gridPos": {"x": 16, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "rate(process_cpu_seconds_total{job=\"polln-colony\"}[5m]) * 100",
            "legendFormat": "CPU %"
          }
        ],
        "options": {
          "min": 0,
          "max": 400,
          "thresholds": [
            {"value": 0, "color": "green"},
            {"value": 200, "color": "yellow"},
            {"value": 350, "color": "red"}
          ]
        }
      },
      {
        "id": 6,
        "title": "Dream Cycle Status",
        "type": "stat",
        "gridPos": {"x": 20, "y": 0, "w": 4, "h": 4},
        "targets": [
          {
            "expr": "time() - polln_dream_cycle_last_timestamp",
            "legendFormat": "Seconds Since Last Dream"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 3600},
                {"color": "red", "value": 7200}
              ]
            }
          }
        }
      },
      {
        "id": 10,
        "title": "Agent Decisions Over Time",
        "type": "graph",
        "gridPos": {"x": 0, "y": 4, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(polln_decisions_total[5m])",
            "legendFormat": "Decisions/sec"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 11,
        "title": "Decision Latency Distribution",
        "type": "graph",
        "gridPos": {"x": 12, "y": 4, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, rate(polln_decision_duration_seconds_bucket[5m]))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, rate(polln_decision_duration_seconds_bucket[5m]))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, rate(polln_decision_duration_seconds_bucket[5m]))",
            "legendFormat": "P99"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 20,
        "title": "KV-Cache Performance",
        "type": "graph",
        "gridPos": {"x": 0, "y": 10, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "rate(polln_anchor_hits_total[5m]) / rate(polln_anchor_lookups_total[5m])",
            "legendFormat": "Hit Rate"
          },
          {
            "expr": "polln_anchor_pool_usage",
            "legendFormat": "Pool Usage"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 21,
        "title": "ANN Lookup Latency",
        "type": "graph",
        "gridPos": {"x": 8, "y": 10, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "histogram_quantile(0.99, rate(polln_ann_lookup_duration_seconds_bucket[5m]))",
            "legendFormat": "P99 ANN Latency"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 22,
        "title": "Anchor Statistics",
        "type": "stat",
        "gridPos": {"x": 16, "y": 10, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "polln_anchors_total",
            "legendFormat": "Total Anchors"
          },
          {
            "expr": "polln_anchor_compression_ratio",
            "legendFormat": "Compression Ratio"
          },
          {
            "expr": "polln_anchor_quality_score",
            "legendFormat": "Quality Score"
          }
        ],
        "options": {
          "graphMode": "none"
        }
      },
      {
        "id": 30,
        "title": "Federated Learning",
        "type": "graph",
        "gridPos": {"x": 0, "y": 16, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(polln_federated_sync_success_total[5m])",
            "legendFormat": "Sync Success Rate"
          },
          {
            "expr": "rate(polln_federated_sync_errors_total[5m])",
            "legendFormat": "Sync Error Rate"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 31,
        "title": "World Model",
        "type": "graph",
        "gridPos": {"x": 12, "y": 16, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "polln_world_model_entropy",
            "legendFormat": "Entropy"
          },
          {
            "expr": "polln_vae_loss",
            "legendFormat": "VAE Loss"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 40,
        "title": "Synapse Health",
        "type": "graph",
        "gridPos": {"x": 0, "y": 22, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "polln_synapses_total",
            "legendFormat": "Total Synapses"
          },
          {
            "expr": "polln_synapse_nan_count",
            "legendFormat": "NaN Synapses"
          },
          {
            "expr": "polln_synapse_corrupted_count",
            "legendFormat": "Corrupted Synapses"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 41,
        "title": "Hebbian Learning",
        "type": "graph",
        "gridPos": {"x": 8, "y": 22, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "rate(polln_hebbian_updates_total[5m])",
            "legendFormat": "Updates/sec"
          },
          {
            "expr": "avg(polln_synapse_weight)",
            "legendFormat": "Avg Weight"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 42,
        "title": "Graph Evolution",
        "type": "stat",
        "gridPos": {"x": 16, "y": 22, "w": 8, "h": 6},
        "targets": [
          {
            "expr": "polln_graph_evolution_pruned_total",
            "legendFormat": "Pruned"
          },
          {
            "expr": "polln_graph_evolution_grafted_total",
            "legendFormat": "Grafted"
          },
          {
            "expr": "polln_graph_evolution_clusters",
            "legendFormat": "Clusters"
          }
        ],
        "options": {
          "graphMode": "none"
        }
      },
      {
        "id": 50,
        "title": "Request Rate",
        "type": "graph",
        "gridPos": {"x": 0, "y": 28, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(polln_requests_total[5m])",
            "legendFormat": "Requests/sec"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 51,
        "title": "Error Rate",
        "type": "graph",
        "gridPos": {"x": 12, "y": 28, "w": 12, "h": 6},
        "targets": [
          {
            "expr": "rate(polln_requests_total{status=~\"5..\"}[5m])",
            "legendFormat": "5xx Errors"
          }
        ],
        "options": {
          "legend": {"showLegend": true}
        }
      },
      {
        "id": 60,
        "title": "SLA Status",
        "type": "stat",
        "gridPos": {"x": 0, "y": 34, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "sum(rate(polln_requests_total{status!~\"5..\"}[5m])) / sum(rate(polln_requests_total[5m]))",
            "legendFormat": "Availability"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "background"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 0.99},
                {"color": "green", "value": 0.999}
              ]
            }
          }
        }
      },
      {
        "id": 61,
        "title": "Error Budget",
        "type": "gauge",
        "gridPos": {"x": 8, "y": 34, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "1 - (sum(rate(polln_requests_total{status=~\"5..\"}[30d])) / sum(rate(polln_requests_total[30d])))",
            "legendFormat": "Error Budget Remaining"
          }
        ],
        "options": {
          "min": 0.99,
          "max": 1,
          "thresholds": [
            {"value": 0.99, "color": "red"},
            {"value": 0.995, "color": "yellow"},
            {"value": 0.999, "color": "green"}
          ]
        }
      },
      {
        "id": 62,
        "title": "Uptime (30d)",
        "type": "stat",
        "gridPos": {"x": 16, "y": 34, "w": 8, "h": 4},
        "targets": [
          {
            "expr": "avg_over_time(up{job=\"polln-colony\"}[30d])",
            "legendFormat": "Uptime"
          }
        ],
        "options": {
          "graphMode": "area",
          "colorMode": "value"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 0.99}
              ]
            }
          }
        }
      }
    ]
  }
}
