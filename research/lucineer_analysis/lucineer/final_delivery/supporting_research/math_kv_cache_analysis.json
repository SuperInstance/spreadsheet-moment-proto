    "part_1_kv_cache_memory_model": {
      "section_1_1_kv_cache_size_derivation": {
        "fundamental_formula": {
          "description": "KV cache stores Key and Value projections for all tokens in sequence",
          "derivation": [
            "For each layer: K = hidden_state @ W_k, V = hidden_state @ W_v",
            "K has shape [seq_len, n_kv_heads, d_head]",
            "V has shape [seq_len, n_kv_heads, d_head]",
            "Total per layer = 2 × n_kv_heads × d_head × seq_len",
            "Total all layers = 2 × n_layers × n_kv_heads × d_head × seq_len",
            "Including bytes: KV_size = 2 × n_layers × n_kv_heads × d_head × seq_len × bytes_per_element"
          ],
          "formula": "KV_cache_size = 2 × n_layers × n_kv_heads × d_head × seq_len × bytes_per_element",
          "units": "bytes"
        },
        "bitnet_2b_parameters": {
          "n_layers": 24,
          "n_attention_heads": 32,
          "n_kv_heads": 8,
          "d_model": 2048,
          "d_head": 64,
          "bytes_per_element_fp16": 2,
          "architecture_note": "Uses Grouped Query Attention (GQA) with 4:1 ratio (32 query heads : 8 KV heads)"
        },
        "per_token_kv_size": {
          "formula": "KV_per_token = 2 × n_layers × n_kv_heads × d_head × bytes_per_element",
          "calculation": "2 × 24 × 8 × 64 × 2 = 49,152 bytes/token",
          "result_bytes": 49152,
          "result_kb": 48.0,
          "breakdown": {
            "K_cache_per_token": "24 layers × 8 heads × 64 dims × 2 bytes = 24,576 bytes",
            "V_cache_per_token": "24 layers × 8 heads × 64 dims × 2 bytes = 24,576 bytes",
            "total": "49,152 bytes per token added"
          }
        },
        "context_length_calculations": {
          "512_tokens": {
            "formula": "49,152 × 512",
            "bytes": 25165824,
            "megabytes": 24.0,
            "per_layer_mb": 1.0
          },
          "1024_tokens": {
            "formula": "49,152 × 1024",
            "bytes": 50331648,
            "megabytes": 48.0,
            "per_layer_mb": 2.0
          },
          "2048_tokens": {
            "formula": "49,152 × 2048",
