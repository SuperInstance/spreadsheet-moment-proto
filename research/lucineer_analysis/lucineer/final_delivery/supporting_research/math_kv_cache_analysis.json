      "section_1_3_exact_memory_access_pattern": {
        "attention_mechanism_breakdown": {
          "step_1_project_query": {
            "operation": "Q_new = hidden_state @ W_q",
            "memory_access": {
              "hidden_state_bytes": "2048 × 2 = 4,096",
              "W_q_bytes": "0 (mask-locked)",
              "Q_new_bytes": "32 × 64 × 2 = 4,096"
            },
            "computation": "2048 × 2048 MACs = 4M ops"
          },
          "step_2_compute_attention_scores": {
            "operation": "scores = Q_new @ K_all^T / sqrt(d_head)",
            "memory_access": {
              "Q_new_bytes": 4096,
              "K_all_bytes": "seq_len × 512 × 2 = seq_len × 1,024",
              "scores_bytes": "32 × seq_len × 2 = seq_len × 64"
            },
            "computation": "32 × seq_len × 64 MACs = seq_len × 2,048 ops"
          },
          "step_3_softmax": {
            "operation": "attention_weights = softmax(scores)",
            "memory_access": {
              "scores_bytes": "seq_len × 64",
              "weights_bytes": "seq_len × 64"
            },
            "computation": "seq_len × 32 exp + seq_len × 32 div"
          },
          "step_4_weighted_sum": {
            "operation": "output = attention_weights @ V_all",
            "memory_access": {
              "weights_bytes": "seq_len × 64",
              "V_all_bytes": "seq_len × 1,024",
              "output_bytes": "32 × 64 × 2 = 4,096"
            },
            "computation": "32 × seq_len × 64 MACs = seq_len × 2,048 ops"
          },
          "step_5_output_projection": {
            "operation": "hidden_new = output @ W_o",
            "memory_access": {
              "output_bytes": 4096,
              "W_o_bytes": "0 (mask-locked)",
              "hidden_new_bytes": 4096
            },
            "computation": "2048 × 2048 MACs = 4M ops"
          }
        },
        "total_bytes_per_token_per_layer": {
          "input_read_bytes": 4096,
          "kv_cache_read_bytes": "seq_len × 2,048",
          "intermediate_bytes": "seq_len × 128 + 8,192",
          "output_write_bytes": 4096,
