    "part_2_bandwidth_bottleneck_analysis": {
      "section_2_1_roofline_model_for_kv_cache": {
        "standard_roofline": {
          "arithmetic_intensity_formula": "AI = FLOPs / bytes_accessed",
          "typical_values": {
            "compute_bound": "AI > peak_FLOPS / peak_bandwidth",
            "memory_bound": "AI < peak_FLOPS / peak_bandwidth"
          }
        },
        "inference_specific_roofline": {
          "derivation": [
            "During prefill: AI_prefill = total_FLOPs / (weight_bytes + activation_bytes)",
            "During decoding: AI_decode = per_token_FLOPs / (KV_cache_bytes + activation_bytes)",
            "For mask-locked: weight_bytes = 0",
            "AI_decode = per_token_FLOPs / KV_cache_bytes"
          ],
          "per_token_flops_calculation": {
            "attention_per_layer": "2 × seq_len × d_model × n_heads + d_model²",
            "ffn_per_layer": "2 × d_model × intermediate_size",
