            "megabytes": 384.0,
            "per_layer_mb": 16.0
          }
        },
        "memory_scaling_analysis": {
          "scaling_law": "O(seq_len) - Linear growth with sequence length",
          "growth_per_1024_tokens_mb": 48.0,
          "implications": [
            "Context doubling = KV cache doubling",
            "4096 context = 192 MB (exceeds typical embedded SRAM)",
            "Must use external memory or aggressive compression for long context"
          ]
        }
      },

      "section_1_2_kv_cache_bandwidth_requirements": {
        "bandwidth_derivation": {
          "description": "During autoregressive decoding, entire KV cache must be read for each token",
          "step_1": "For each new token generation, attention computes: softmax(Q_new @ K_all^T) @ V_all",
          "step_2": "Q_new is single vector (constant size)",
          "step_3": "K_all and V_all grow linearly with seq_len",
          "step_4": "Each token requires reading entire K and V matrices",
          "total_reads_per_token": "2 × KV_cache_size (K read + V read)",
          "formula": "Bandwidth = KV_cache_size × 2 × tokens_per_second"
        },
        "bandwidth_calculations": {
