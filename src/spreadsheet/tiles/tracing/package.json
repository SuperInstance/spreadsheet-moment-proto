{
  "name": "@polln/tile-tracer",
  "version": "1.0.0",
  "description": "Production-quality tile execution tracer with span-based tracing, confidence tracking, and export capabilities",
  "main": "tile-tracer.ts",
  "types": "tile-tracer.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "example": "ts-node example.ts"
  },
  "keywords": [
    "tracing",
    "observability",
    "monitoring",
    "debugging",
    "profiling",
    "opentelemetry",
    "jaeger",
    "zipkin",
    "distributed-tracing",
    "confidence-tracking",
    "stigmergy",
    "tiles",
    "spreadsheet"
  ],
  "author": "SuperInstance.AI",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SuperInstance/polln",
    "directory": "src/spreadsheet/tiles/tracing"
  },
  "peerDependencies": {
    "typescript": ">=4.9.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "tile-tracer.ts",
      "!*.test.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 80,
        "functions": 80,
        "lines": 80,
        "statements": 80
      }
    }
  },
  "exports": {
    ".": {
      "import": "./tile-tracer.ts",
      "types": "./tile-tracer.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "tile-tracer.ts",
    "tile-tracer.test.ts",
    "example.ts",
    "README.md",
    "QUICKSTART.md",
    "ARCHITECTURE.md",
    "IMPLEMENTATION_SUMMARY.md"
  ]
}
