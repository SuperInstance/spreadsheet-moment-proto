  "formulas": {
    "SUM": {
      "name": "SUM",
      "localName": "SUM",
      "syntax": "SUM(number1, [number2], ...)",
      "description": "جمع كل الأرقام في نطاق من الخلايا",
      "parameters": {
        "number1": "الرقم الأول أو النطاق",
        "number2": "أرقام أو نطاقات إضافية (اختياري)"
      },
      "examples": [
        "=SUM(A1:A10)",
        "=SUM(A1, B1, C1)"
      ]
    },
    "AVERAGE": {
      "name": "AVERAGE",
      "localName": "AVERAGE",
      "syntax": "AVERAGE(number1, [number2], ...)",
      "description": "إرجاع المتوسط (الحسابي) للوسائط",
      "parameters": {
        "number1": "الرقم الأول أو النطاق",
        "number2": "أرقام أو نطاقات إضافية (اختياري)"
      },
      "examples": [
        "=AVERAGE(A1:A10)",
        "=AVERAGE(A1, B1, C1)"
      ]
    },
    "COUNT": {
      "name": "COUNT",
      "localName": "COUNT",
      "syntax": "COUNT(value1, [value2], ...)",
      "description": "يحسب عدد الخلايا التي تحتوي على أرقام",
      "parameters": {
        "value1": "القيمة الأولى أو النطاق",
        "value2": "قيم أو نطاقات إضافية (اختياري)"
      },
      "examples": [
        "=COUNT(A1:A10)",
        "=COUNT(A1, B1, C1)"
      ]
    },
    "IF": {
      "name": "IF",
      "localName": "IF",
      "syntax": "IF(logical_test, value_if_true, [value_if_false])",
      "description": "يتحقق مما إذا كان الشرط مستوفىً ويرجع قيمة واحدة إذا كان صحيحًا وقيمة أخرى إذا كان خطأ",
      "parameters": {
        "logical_test": "الشرط للاختبار",
        "value_if_true": "القيمة المرجعة إذا كان الشرط صحيحًا",
        "value_if_false": "القيمة المرجعة إذا كان الشرط خطأ (اختياري)"
      },
      "examples": [
        '=IF(A1>10, "مرتفع", "منخفض")',
        '=IF(A1="", "فارغ", A1)'
      ]
    },
    "VLOOKUP": {
      "name": "VLOOKUP",
      "localName": "VLOOKUP",
      "syntax": "VLOOKUP(lookup_value, table_array, col_index_num, [range_lookup])",
      "description": "يبحث عن قيمة في العمود الأيسر من جدول ويرجع قيمة في نفس الصف من عمود تحدده",
      "parameters": {
        "lookup_value": "القيمة للبحث عنها",
        "table_array": "النطاق الذي يحتوي على البيانات",
        "col_index_num": "رقم العمود لرجوع القيمة منه",
        "range_lookup": "تطابق تام (FALSE) أو تقريبي (TRUE، اختياري)"
      },
      "examples": [
        "=VLOOKUP(A1, B1:D10, 2, FALSE)",
        '=VLOOKUP("منتج", A1:D100, 3, TRUE)'
      ]
    }
  },
