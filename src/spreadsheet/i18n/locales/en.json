  "formulas": {
    "SUM": {
      "name": "SUM",
      "localName": "SUM",
      "syntax": "SUM(number1, [number2], ...)",
      "description": "Adds all the numbers in a range of cells",
      "parameters": {
        "number1": "First number or range",
        "number2": "Additional numbers or ranges (optional)"
      },
      "examples": [
        "=SUM(A1:A10)",
        "=SUM(A1, B1, C1)"
      ]
    },
    "AVERAGE": {
      "name": "AVERAGE",
      "localName": "AVERAGE",
      "syntax": "AVERAGE(number1, [number2], ...)",
      "description": "Returns the average (arithmetic mean) of the arguments",
      "parameters": {
        "number1": "First number or range",
        "number2": "Additional numbers or ranges (optional)"
      },
      "examples": [
        "=AVERAGE(A1:A10)",
        "=AVERAGE(A1, B1, C1)"
      ]
    },
    "COUNT": {
      "name": "COUNT",
      "localName": "COUNT",
      "syntax": "COUNT(value1, [value2], ...)",
      "description": "Counts the number of cells that contain numbers",
      "parameters": {
        "value1": "First value or range",
        "value2": "Additional values or ranges (optional)"
      },
      "examples": [
        "=COUNT(A1:A10)",
        "=COUNT(A1, B1, C1)"
      ]
    },
    "IF": {
      "name": "IF",
      "localName": "IF",
      "syntax": "IF(logical_test, value_if_true, [value_if_false])",
      "description": "Checks whether a condition is met and returns one value if true and another value if false",
      "parameters": {
        "logical_test": "Condition to test",
        "value_if_true": "Value to return if condition is true",
        "value_if_false": "Value to return if condition is false (optional)"
      },
      "examples": [
        "=IF(A1>10, \"High\", \"Low\")",
        "=IF(A1=\"\", \"Empty\", A1)"
      ]
    },
    "VLOOKUP": {
      "name": "VLOOKUP",
      "localName": "VLOOKUP",
      "syntax": "VLOOKUP(lookup_value, table_array, col_index_num, [range_lookup])",
      "description": "Looks for a value in the leftmost column of a table and returns a value in the same row from a column you specify",
      "parameters": {
        "lookup_value": "Value to search for",
        "table_array": "Range containing the data",
        "col_index_num": "Column number to return value from",
        "range_lookup": "Exact match (FALSE) or approximate match (TRUE, optional)"
      },
      "examples": [
        "=VLOOKUP(A1, B1:D10, 2, FALSE)",
        "=VLOOKUP(\"Product\", A1:D100, 3, TRUE)"
      ]
    }
  },
