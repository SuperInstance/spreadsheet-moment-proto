  "formulas": {
    "SUM": {
      "name": "SUM",
      "localName": "SUMA",
      "syntax": "SUMA(número1, [número2], ...)",
      "description": "Suma todos los números en un rango de celdas",
      "parameters": {
        "number1": "Primer número o rango",
        "number2": "Números o rangos adicionales (opcional)"
      },
      "examples": [
        "=SUMA(A1:A10)",
        "=SUMA(A1; B1; C1)"
      ]
    },
    "AVERAGE": {
      "name": "AVERAGE",
      "localName": "PROMEDIO",
      "syntax": "PROMEDIO(número1, [número2], ...)",
      "description": "Devuelve el promedio (media aritmética) de los argumentos",
      "parameters": {
        "number1": "Primer número o rango",
        "number2": "Números o rangos adicionales (opcional)"
      },
      "examples": [
        "=PROMEDIO(A1:A10)",
        "=PROMEDIO(A1; B1; C1)"
      ]
    },
    "COUNT": {
      "name": "COUNT",
      "localName": "CONTAR",
      "syntax": "CONTAR(valor1, [valor2], ...)",
      "description": "Cuenta el número de celdas que contienen números",
      "parameters": {
        "value1": "Primer valor o rango",
        "value2": "Valores o rangos adicionales (opcional)"
      },
      "examples": [
        "=CONTAR(A1:A10)",
        "=CONTAR(A1; B1; C1)"
      ]
    },
    "IF": {
      "name": "IF",
      "localName": "SI",
      "syntax": "SI(prueba_lógica, valor_si_verdadero, [valor_si_falso])",
      "description": "Verifica si se cumple una condición y devuelve un valor si es verdadero y otro valor si es falso",
      "parameters": {
        "logical_test": "Condición a probar",
        "value_if_true": "Valor a devolver si la condición es verdadera",
        "value_if_false": "Valor a devolver si la condición es falsa (opcional)"
      },
      "examples": [
        "=SI(A1>10; \"Alto\", \"Bajo\")",
        "=SI(A1=\"\"; \"Vacío\", A1)"
      ]
    },
    "VLOOKUP": {
      "name": "VLOOKUP",
      "localName": "BUSCARV",
      "syntax": "BUSCARV(valor_buscado, rango, indicador_columnas, [coincidencia])",
      "description": "Busca un valor en la primera columna de una tabla y devuelve un valor en la misma fila desde una columna especificada",
      "parameters": {
        "lookup_value": "Valor a buscar",
        "table_array": "Rango que contiene los datos",
        "col_index_num": "Número de columna desde la cual devolver el valor",
        "range_lookup": "Coincidencia exacta (FALSO) o aproximada (VERDADERO, opcional)"
      },
      "examples": [
        "=BUSCARV(A1; B1:D10; 2; FALSO)",
        "=BUSCARV(\"Producto\"; A1:D100; 3; VERDADERO)"
      ]
    }
  },
